---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/paths';
import { getBlogEntries, type BlogEntry } from '../../data/blog';

export async function getStaticPaths() {
  const posts = await getBlogEntries();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogEntry };
const { Content } = await post.render();
const dateFormatter = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <section class="container blog-post-shell">
    <p class="blog-back-link">
      <a href={withBase('/blog')}>Back to blog</a>
    </p>

    <article class="blog-post">
      <header class="blog-post-header">
        <p class="blog-post-date">
          <span>{dateFormatter.format(post.data.pubDate)}</span>
          {post.data.updatedDate && <span>Updated {dateFormatter.format(post.data.updatedDate)}</span>}
        </p>
        <h1>{post.data.title}</h1>
        <p class="blog-post-description">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <p class="blog-post-tags">{post.data.tags.map((tag) => `#${tag}`).join(' ')}</p>
        )}
      </header>

      <div class="markdown blog-post-body">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .blog-post-shell {
    max-width: 56rem;
  }

  .blog-back-link {
    margin-bottom: 1rem;
  }

  .blog-post {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: var(--shadow-card);
  }

  .blog-post-header h1 {
    margin-bottom: 0.75rem;
  }

  .blog-post-date,
  .blog-post-description,
  .blog-post-tags {
    color: var(--muted);
  }

  .blog-post-date {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .blog-post-body {
    margin-top: 2rem;
  }
</style>
