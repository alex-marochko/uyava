---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { IDE_PLUGINS } from '../config';
import { withBase } from '../utils/paths';

const hasJetBrainsMarketplace = IDE_PLUGINS.jetbrainsMarketplace.trim().length > 0;
const jetBrainsHref = hasJetBrainsMarketplace
  ? IDE_PLUGINS.jetbrainsMarketplace
  : IDE_PLUGINS.jetbrainsMarketplaceSearch;
---
<BaseLayout title="Download" description="Download the free desktop app or get the DevTools extension.">
  <section class="container">
    <SectionHeader
      eyebrow="Download"
      title="Desktop app installers"
      description="Desktop is free. Desktop Pro unlocks advanced replay features."
    />
    <div class="card download-beta-note">
      <p>
        Desktop installers are currently in <strong>Public Beta</strong>. We are collecting feedback
        before the stable release.
      </p>
    </div>
    <div class="download-grid">
      <div class="download-card">
        <h3>macOS</h3>
        <p>Installer (.dmg)</p>
        <span class="pill">Coming soon</span>
      </div>
      <div class="download-card">
        <h3>Windows</h3>
        <p>Installer (.exe / .msi)</p>
        <span class="pill">Coming soon</span>
      </div>
      <div class="download-card">
        <h3>Linux</h3>
        <p>AppImage</p>
        <span class="pill">Coming soon</span>
      </div>
    </div>
    <div class="card">
      <p>
        Desktop is free to use. Desktop Pro adds advanced replay and navigation
        for .uyava logs. <a href={withBase('/pricing')}>See pricing</a>.
      </p>
    </div>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="DevTools"
      title="Get the DevTools extension"
      description="The free DevTools extension lives in the documentation."
    />
    <a class="btn primary" href={withBase('/docs/installation')}>Go to installation</a>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="IDE Plugins"
      title="Install IDE launchers for Desktop"
      description="Open or attach Uyava Desktop directly from VS Code and Android Studio."
    />
    <div class="download-grid">
      <div class="download-card">
        <h3>VS Code</h3>
        <p>Uyava Desktop Launcher</p>
        <a class="btn" href={IDE_PLUGINS.vscodeMarketplace} target="_blank" rel="noreferrer">
          Open VS Code Marketplace
        </a>
      </div>
      <div class="download-card">
        <h3>Android Studio / IntelliJ</h3>
        <p>Uyava Desktop Launcher</p>
        <a class="btn" href={jetBrainsHref} target="_blank" rel="noreferrer">
          {hasJetBrainsMarketplace
            ? 'Open JetBrains Marketplace'
            : 'JetBrains listing (coming soon)'}
        </a>
      </div>
    </div>
    <div class="card plugin-guide-card">
      <p>
        Full setup guide: <a href={withBase('/docs/ide-plugins')}>IDE Plugins documentation</a>.
      </p>
    </div>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="Releases"
      title="Changelogs and release notes"
      description="Release artifacts will be published to GitHub Releases."
    />
    <a class="btn" href="https://github.com/alex-marochko/uyava/releases" target="_blank" rel="noreferrer">
      View releases
    </a>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="Requirements"
      title="System requirements"
      description="Lightweight by default, with room for larger recordings."
    />
    <div class="card">
      <ul>
        <li>macOS 12+, Windows 10+, or modern Linux (x86_64).</li>
        <li>Flutter app running with DevTools enabled.</li>
        <li>8 GB RAM recommended for long sessions.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
