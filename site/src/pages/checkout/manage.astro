---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { withBase } from '../../utils/paths';

const billingApiBase = (import.meta.env.PUBLIC_BILLING_API_BASE ?? '').trim();
---
<BaseLayout
  title="Manage Subscription"
  description="Cancel your Uyava Desktop Pro subscription."
>
  <section class="container">
    <SectionHeader
      eyebrow="Subscription"
      title="Manage Desktop Pro subscription"
      description="Use your license key and purchase email to cancel future renewals."
    />

    <div class="grid two">
      <div class="card">
        <h3>Verify access</h3>
        <p class="checkout-note">
          For security, management actions require both your license key and the same email used in Paddle checkout.
        </p>
        <div class="manage-fields">
          <label for="manage-license-key">License key</label>
          <input id="manage-license-key" type="text" autocomplete="off" placeholder="AAAA-BBBB-CCCC-0001" />
          <label for="manage-email">Purchase email</label>
          <input id="manage-email" type="email" autocomplete="email" placeholder="you@example.com" />
        </div>
      </div>

      <div class="card">
        <h3>Actions</h3>
        <div class="hero-actions">
          <button class="btn primary" id="manage-cancel" type="button">
            Cancel subscription
          </button>
        </div>
        <p class="checkout-status" id="manage-status" role="status" aria-live="polite"></p>
      </div>
    </div>

    <div class="card manage-help-card">
      <h3>Need help?</h3>
      <p>If verification fails, contact support and include your license key and Paddle receipt.</p>
      <a class="btn" href={withBase('/contact')}>Contact support</a>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ billingApiBase }}>
  (() => {
    const licenseInput = document.getElementById('manage-license-key');
    const emailInput = document.getElementById('manage-email');
    const statusEl = document.getElementById('manage-status');
    const cancelBtn = document.getElementById('manage-cancel');
    const allButtons = [cancelBtn].filter(Boolean);
    const apiBase = (billingApiBase || '').trim();

    const setStatus = (message, isError = false) => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.dataset.state = isError ? 'error' : 'ok';
    };

    const setBusy = (busy) => {
      for (const button of allButtons) {
        button.disabled = busy;
      }
    };

    const readPayload = () => {
      const licenseKey = (licenseInput?.value || '').trim();
      const email = (emailInput?.value || '').trim();
      if (!licenseKey || !email) {
        setStatus('Enter license key and purchase email first.', true);
        return null;
      }
      return { licenseKey, email };
    };

    const endpoint = (path) => {
      if (!apiBase) return '';
      return `${apiBase.replace(/\/+$/, '')}${path}`;
    };

    const toManageErrorMessage = ({ status, body, error }) => {
      const code = typeof body?.error === 'string' ? body.error : '';
      if (code === 'forbidden' || status === 403) {
        return 'Email does not match this license';
      }
      if (code === 'validation_error' || status === 400) {
        return 'Please enter a valid license key and purchase email.';
      }
      if (code === 'not_ready' || status === 409) {
        return 'Subscription management is not ready for this purchase yet. Please try again later.';
      }
      if (code === 'not_found' || status === 404) {
        return 'License not found. Check the key and try again.';
      }
      if (code === 'paddle_api_error' || code === 'internal_error' || status >= 500) {
        return 'Subscription management is temporarily unavailable. Please try again later.';
      }
      if (error instanceof TypeError) {
        return 'Unable to reach billing service. Check your connection and try again.';
      }
      return 'Unexpected request error. Please try again later.';
    };

    const postAction = async (path, payload, pendingMessage, successMessage) => {
      const url = endpoint(path);
      if (!url) {
        setStatus('Billing API is not configured for this site build.', true);
        return;
      }
      setBusy(true);
      setStatus(pendingMessage);
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const body = await response.json().catch(() => ({}));
        if (!response.ok || !body.ok) {
          console.error('Manage billing action failed', {
            path,
            status: response.status,
            body,
          });
          throw new Error(
            toManageErrorMessage({ status: response.status, body }),
          );
        }
        setStatus(successMessage);
      } catch (error) {
        if (!(error instanceof Error)) {
          console.error('Manage billing action error', error);
        }
        const message =
          error instanceof Error && error.message
            ? error.message
            : toManageErrorMessage({ error });
        setStatus(message, true);
      } finally {
        setBusy(false);
      }
    };

    cancelBtn?.addEventListener('click', () => {
      const payload = readPayload();
      if (!payload) return;
      void postAction(
        '/billing/subscription/cancel',
        { ...payload, effectiveFrom: 'next_billing_period' },
        'Scheduling cancellation...',
        'Cancellation scheduled for next billing period.',
      );
    });
  })();
</script>
