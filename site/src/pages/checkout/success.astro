---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { withBase } from '../../utils/paths';

const billingApiBase = (import.meta.env.PUBLIC_BILLING_API_BASE ?? '').trim();
---
<BaseLayout
  title="Purchase Received"
  description="Your Paddle payment was received. Activate Desktop Pro with your license key."
>
  <section class="container">
    <SectionHeader
      eyebrow="Checkout"
      title="Payment received"
      description="Your order is processing. If the key is not shown immediately, wait a few seconds and refresh this page."
    />
    <div class="grid two">
      <div class="card">
        <h3>Your license key</h3>
        <p id="claim-status">
          Looking up your key...
        </p>
        <code id="license-key-value" class="checkout-license-key" hidden></code>
        <div class="hero-actions">
          <button id="copy-license-key" class="btn primary" type="button" hidden>
            Copy key
          </button>
          <a class="btn" href={withBase('/pricing')}>Back to pricing</a>
        </div>
        <p class="checkout-note">
          Save this key in a secure place before closing this page.
        </p>
      </div>
      <div class="card">
        <h3>Next step in Desktop</h3>
        <p>
          Open Desktop, paste your license key in the activation screen, and
          complete activation.
        </p>
        <a class="btn primary" href={withBase('/download')}>Open Desktop Download</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ billingApiBase }}>
  (() => {
    const statusEl = document.getElementById('claim-status');
    const keyEl = document.getElementById('license-key-value');
    const copyBtn = document.getElementById('copy-license-key');
    const transactionIdFromQuery =
      new URLSearchParams(window.location.search).get('_ptxn')?.trim() || '';
    const transactionIdFromStorage =
      localStorage.getItem('uyava_checkout_last_transaction_id')?.trim() || '';
    const transactionId = transactionIdFromQuery || transactionIdFromStorage;
    const customerId = localStorage.getItem('uyava_checkout_customer_id')?.trim() || '';
    const apiBase = (billingApiBase || '').trim();

    const setStatus = (message, isError = false) => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.style.color = isError ? '#ff9870' : '';
    };

    const endpoint = () => {
      if (!apiBase) return '';
      return `${apiBase.replace(/\/+$/, '')}/billing/license/claim`;
    };

    const toClaimErrorMessage = ({ status, payload, error }) => {
      const code = typeof payload?.error === 'string' ? payload.error : '';
      if (code === 'validation_error' || status === 400) {
        return 'Invalid checkout link. Please return to pricing and try again.';
      }
      if (code === 'not_ready' || status === 409) {
        return 'Your purchase is still processing. Please refresh this page in a moment.';
      }
      if (code === 'not_found' || status === 404) {
        return 'Purchase not found yet. Please refresh this page in a moment.';
      }
      if (code === 'paddle_api_error' || code === 'internal_error' || status >= 500) {
        return 'Unable to load your license key right now. Please refresh this page in a moment.';
      }
      if (error instanceof TypeError) {
        return 'Unable to reach billing service. Check your connection and try again.';
      }
      return 'Unable to load your license key right now.';
    };

    const revealKey = (licenseKey) => {
      if (!keyEl || !copyBtn) return;
      keyEl.hidden = false;
      keyEl.textContent = licenseKey;
      copyBtn.hidden = false;
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(licenseKey);
          setStatus('License key copied.');
        } catch (_) {
          setStatus('Unable to copy key. Please copy it manually.', true);
        }
      });
    };

    const loadKey = async () => {
      if (transactionIdFromQuery) {
        localStorage.setItem('uyava_checkout_last_transaction_id', transactionIdFromQuery);
      }
      if (!transactionId) {
        setStatus('Missing transaction id. Open checkout from pricing in this browser and try again.', true);
        return;
      }
      if (!customerId) {
        setStatus('Missing customer id in this browser. Open checkout from this browser and try again.', true);
        return;
      }
      const claimEndpoint = endpoint();
      if (!claimEndpoint) {
        setStatus('Billing API is not configured for this site build.', true);
        return;
      }

      try {
        const maxAttempts = 25;
        const retryDelayMs = 2000;
        for (let attempt = 1; attempt <= maxAttempts; attempt += 1) {
          if (attempt > 1) {
            setStatus(`Finalizing purchase... (${attempt}/${maxAttempts})`);
            await new Promise((resolve) => setTimeout(resolve, retryDelayMs));
          }

          const response = await fetch(claimEndpoint, {
            method: 'POST',
            headers: {
              'content-type': 'application/json',
            },
            body: JSON.stringify({
              transactionId,
              customerId,
            }),
          });
          const payload = await response.json().catch(() => ({}));
          if (response.ok && payload.ok) {
            if (typeof payload.licenseKey !== 'string' || payload.licenseKey.length === 0) {
              console.error('Claim response missing licenseKey', payload);
              throw new Error(
                'Unable to load your license key right now. Please refresh this page in a moment.',
              );
            }
            revealKey(payload.licenseKey);
            setStatus('License key ready.');
            return;
          }

          const notReady =
            response.status === 409 ||
            payload?.error === 'not_ready' ||
            /not found for transaction/i.test(String(payload?.message || ''));
          if (!notReady) {
            console.error('License claim failed', {
              status: response.status,
              payload,
            });
            throw new Error(
              toClaimErrorMessage({ status: response.status, payload }),
            );
          }
        }
        throw new Error('License is still processing. Please refresh this page in a moment.');
      } catch (error) {
        if (!(error instanceof Error)) {
          console.error('License claim error', error);
        }
        const message =
          error instanceof Error && error.message
            ? error.message
            : toClaimErrorMessage({ error });
        setStatus(`${message} Contact support if this persists.`, true);
      }
    };

    void loadKey();
  })();
</script>
