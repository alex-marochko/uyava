---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { withBase } from '../utils/paths';

const billingApiBase = (import.meta.env.PUBLIC_BILLING_API_BASE ?? '').trim();
const billingProductId = (import.meta.env.PUBLIC_BILLING_PRODUCT_ID ?? 'desktop_pro').trim();
---
<BaseLayout title="Pricing" description="Choose between free DevTools, free Desktop, or Desktop Pro.">
  <section class="container">
    <SectionHeader
      eyebrow="Pricing"
      title="Three options, one workflow"
      description="Use the free extension or free desktop app, then upgrade to Desktop Pro when needed."
    />
    <div class="grid three">
      <div class="card pricing-card">
        <p class="pill">Free</p>
        <h3>DevTools Extension</h3>
        <p class="price">$0</p>
        <ul>
          <li>DevTools extension (open-source, MIT).</li>
          <li>Core visualization and navigation.</li>
          <li>Filters, grouping, and event chains.</li>
        </ul>
        <a class="btn" href={withBase('/download')}>Get started</a>
      </div>
      <div class="card pricing-card">
        <p class="pill">Free · Desktop</p>
        <h3>Desktop App</h3>
        <p class="price">$0</p>
        <ul>
          <li>Desktop performance for larger graphs.</li>
          <li>IDE integration to jump from map to code.</li>
          <li>Record and preview .uyava logs.</li>
        </ul>
        <a class="btn" href={withBase('/download')}>Download</a>
      </div>
      <div class="card pricing-card highlight">
        <p class="pill">Pro · Desktop</p>
        <h3>Desktop Pro</h3>
        <p class="price">
          $8<span class="price-unit">/month</span>
        </p>
        <ul>
          <li>Advanced replay and navigation for .uyava logs.</li>
          <li>Seekbar controls for long sessions.</li>
        </ul>
        <div
          class="checkout-actions"
          id="checkout-actions"
          data-billing-api-base={billingApiBase}
          data-product-id={billingProductId}
        >
          <label class="checkout-field-label" for="checkout-email">
            Email for license delivery and subscription cancellation
          </label>
          <input
            id="checkout-email"
            class="checkout-email-input"
            type="email"
            inputmode="email"
            autocomplete="email"
            placeholder="you@example.com"
            required
          />
          <button class="btn primary" type="button" data-checkout-plan="monthly">
            Start subscription · $8/month
          </button>
          <p class="checkout-status" id="checkout-status" role="status" aria-live="polite"></p>
          <p class="checkout-note">
            After purchase, activate Pro in Desktop with your license key.
          </p>
        </div>
        <noscript>
          <a class="btn primary" href={withBase('/contact')}>Request access</a>
        </noscript>
      </div>
    </div>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="FAQ"
      title="Common questions"
      description="Short answers before you reach out."
    />
    <div class="grid two">
      <div class="card">
        <h3>How are payments handled?</h3>
        <p>Payments and invoices are processed by Paddle.</p>
        <a class="btn small" href={withBase('/checkout/manage')}>Manage subscription</a>
      </div>
      <div class="card">
        <h3>Do you offer a free trial?</h3>
        <p>
          No. Desktop Pro does not include a trial period. You can use the free
          Desktop app and DevTools, then upgrade when needed.
        </p>
      </div>
      <div class="card">
        <h3>What about refunds?</h3>
        <p>See the refund policy for details on eligibility and timelines.</p>
        <a class="btn small" href={withBase('/legal/refunds')}>Refund policy</a>
      </div>
      <div class="card">
        <h3>How does licensing work?</h3>
        <p>
          Desktop is free to use without activation. Desktop Pro uses license
          keys and each key can be activated on up to 2 devices.
        </p>
      </div>
      <div class="card">
        <h3>Do I get a new key every month?</h3>
        <p>
          No. Your subscription keeps the same Desktop Pro key active. Renewals
          update entitlement status without requiring a new key.
        </p>
      </div>
      <div class="card">
        <h3>How do I cancel my subscription?</h3>
        <p>
          Use the Manage subscription page with your license key and purchase
          email to stop future renewals.
        </p>
      </div>
      <div class="card">
        <h3>When can access be revoked?</h3>
        <p>
          Access may be revoked if subscription status becomes canceled, past
          due, payment failed, or an approved refund/chargeback is processed.
        </p>
      </div>
      <div class="card">
        <h3>Can I stay on Free?</h3>
        <p>Yes. Both the DevTools extension and Desktop app are free to use.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.getElementById('checkout-actions');
    if (!root) return;

    const statusEl = document.getElementById('checkout-status');
    const emailInput = document.getElementById('checkout-email');
    const buttons = Array.from(root.querySelectorAll('button[data-checkout-plan]'));
    const billingApiBase = (root.dataset.billingApiBase || '').trim();
    const productId = (root.dataset.productId || 'desktop_pro').trim();

    const setStatus = (message, isError = false) => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.dataset.state = isError ? 'error' : 'ok';
    };

    const setBusy = (busy) => {
      for (const button of buttons) {
        button.disabled = busy;
      }
      if (emailInput) {
        emailInput.disabled = busy;
      }
    };

    const normalizeEmail = (value) => (value || '').trim().toLowerCase();
    const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

    const createStableCustomerId = () => {
      const storageKey = 'uyava_checkout_customer_id';
      const existing = localStorage.getItem(storageKey);
      if (existing && /^web_[a-z0-9_-]{8,}$/i.test(existing)) return existing;

      let randomPart = '';
      if (window.crypto && typeof window.crypto.randomUUID === 'function') {
        randomPart = window.crypto.randomUUID().replace(/-/g, '');
      } else {
        randomPart = `${Date.now().toString(36)}${Math.random().toString(36).slice(2)}`;
      }
      const customerId = `web_${randomPart}`;
      localStorage.setItem(storageKey, customerId);
      return customerId;
    };

    const createIdempotencyKey = (plan) => {
      const random = Math.random().toString(36).slice(2, 10);
      return `site-${plan}-${Date.now().toString(36)}-${random}`;
    };

    const rememberLastTransactionId = (transactionId) => {
      const normalized = (transactionId || '').trim();
      if (!normalized) return;
      localStorage.setItem('uyava_checkout_last_transaction_id', normalized);
    };

    const buildCheckoutUrl = () => {
      if (!billingApiBase) return '';
      return `${billingApiBase.replace(/\/+$/, '')}/billing/checkout`;
    };

    const onCheckoutClick = async (plan) => {
      const endpoint = buildCheckoutUrl();
      if (!endpoint) {
        setStatus('Checkout is temporarily unavailable. Please contact support.', true);
        return;
      }
      const email = normalizeEmail(emailInput?.value);
      if (!isValidEmail(email)) {
        setStatus('Enter a valid email address before checkout.', true);
        return;
      }

      setBusy(true);
      setStatus('Creating secure checkout session...');

      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: {
            'content-type': 'application/json',
          },
          body: JSON.stringify({
            customerId: createStableCustomerId(),
            email,
            productId,
            plan,
            successUrl: `${window.location.origin}/checkout/success`,
            cancelUrl: `${window.location.origin}/checkout/cancel`,
            idempotencyKey: createIdempotencyKey(plan),
          }),
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok || !payload.ok) {
          const message =
            payload?.message ||
            (response.status === 409
              ? 'An active entitlement already exists for this account.'
              : `Checkout failed (${response.status}).`);
          throw new Error(message);
        }

        if (typeof payload.checkoutUrl !== 'string' || payload.checkoutUrl.length === 0) {
          throw new Error('Checkout URL is missing in backend response.');
        }
        if (typeof payload.transactionId === 'string' && payload.transactionId.length > 0) {
          rememberLastTransactionId(payload.transactionId);
        }

        setStatus('Redirecting to Paddle...');
        window.location.assign(payload.checkoutUrl);
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Unexpected checkout error.';
        setStatus(message, true);
        setBusy(false);
      }
    };

    for (const button of buttons) {
      button.addEventListener('click', () => {
        const plan = button.dataset.checkoutPlan;
        if (plan !== 'monthly') {
          setStatus('Invalid plan selected.', true);
          return;
        }
        void onCheckoutClick(plan);
      });
    }
  })();
</script>
