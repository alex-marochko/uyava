---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Callout from '../components/Callout.astro';
import { withBase } from '../utils/paths';
---
<BaseLayout hideNavBrand={true}>
  <section class="hero container">
    <div class="hero-grid">
      <div class="reveal">
        <h1>Your app&apos;s live map</h1>
        <p class="hero-subtitle">Visual debugging &amp; event replay for Flutter apps.</p>
        <p class="name-note">
          “Uyava” means “imagination” in Ukrainian (pronounced “oo-YAH-vah”).
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={withBase('/download')}>Download</a>
          <a class="btn" href={withBase('/docs')}>Read docs</a>
          <a class="btn" href={withBase('/pricing')}>View pricing</a>
        </div>
      </div>
      <div class="hero-logo-panel reveal" style="animation-delay: 0.15s;">
        <img
          class="hero-logo"
          src={withBase('/images/uyava_logo_n_text_horizontal_large_dark.png')}
          alt="Uyava logo"
        />
      </div>
    </div>
    <div class="hero-support reveal grid two" style="animation-delay: 0.25s;">
      <div class="hero-card">
        <h3>What it helps with</h3>
        <ul class="hero-benefits">
          <li>See runtime behavior as an interactive architecture graph.</li>
          <li>Trace event paths and chain reactions across features.</li>
          <li>Inspect nodes, relationships, and metrics in one view.</li>
          <li>Replay sessions recorded by QA to reproduce tricky bugs instantly.</li>
          <li>Onboard developers instantly with a living map instead of outdated text docs.</li>
        </ul>
      </div>
      <div class="hero-visual hero-video-card">
        <button
          class="hero-video-trigger"
          type="button"
          data-hero-video-open
          aria-label="Open full Uyava desktop demo"
        >
          <video
            class="hero-video-preview"
            data-hero-video-preview
            muted
            loop
            playsinline
            preload="none"
            poster={withBase('/images/hero_courier_burst_poster.webp')}
          >
            <source src={withBase('/images/hero_courier_burst_preview.webm')} type="video/webm" />
            <source src={withBase('/images/hero_courier_burst_preview.mp4')} type="video/mp4" />
          </video>
          <span class="hero-video-overlay">Watch full demo</span>
        </button>
        <p class="caption">
          Courier Live Burst preview. Hover to play on desktop, tap to open on mobile.
        </p>
      </div>
    </div>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="Core capabilities"
      title="Short feature overview"
    />
    <div class="grid feature-grid">
      <div class="card reveal feature-card">
        <button
          class="feature-video-trigger"
          type="button"
          data-feature-video-trigger
          data-feature-title="Live Architecture Graph"
          data-feature-full-webm={withBase('/images/feature_live_graph_preview.webm')}
          data-feature-full-mp4={withBase('/images/feature_live_graph_preview.mp4')}
          data-feature-poster={withBase('/images/feature_live_graph_poster.webp')}
          aria-label="Open full demo for Live Architecture Graph"
        >
          <video
            class="feature-video-preview"
            data-feature-video
            muted
            loop
            playsinline
            preload="none"
            poster={withBase('/images/feature_live_graph_poster.webp')}
          >
            <source src={withBase('/images/feature_live_graph_preview.webm')} type="video/webm" />
            <source src={withBase('/images/feature_live_graph_preview.mp4')} type="video/mp4" />
          </video>
          <span class="feature-video-overlay">Open demo</span>
        </button>
        <h3>Live Architecture Graph</h3>
        <p>
          See nodes and edges as the app runs, so structure is visible during debugging.
        </p>
      </div>
      <div class="card reveal feature-card" style="animation-delay: 0.05s;">
        <button
          class="feature-video-trigger"
          type="button"
          data-feature-video-trigger
          data-feature-title="Event Flow Animation"
          data-feature-full-webm={withBase('/images/feature_event_flow_preview.webm')}
          data-feature-full-mp4={withBase('/images/feature_event_flow_preview.mp4')}
          data-feature-poster={withBase('/images/feature_event_flow_poster.webp')}
          aria-label="Open full demo for Event Flow Animation"
        >
          <video
            class="feature-video-preview"
            data-feature-video
            muted
            loop
            playsinline
            preload="none"
            poster={withBase('/images/feature_event_flow_poster.webp')}
          >
            <source src={withBase('/images/feature_event_flow_preview.webm')} type="video/webm" />
            <source src={withBase('/images/feature_event_flow_preview.mp4')} type="video/mp4" />
          </video>
          <span class="feature-video-overlay">Open demo</span>
        </button>
        <h3>Event Flow Animation</h3>
        <p>
          Watch events move through the graph to understand cause and effect quickly.
        </p>
      </div>
      <div class="card reveal feature-card" style="animation-delay: 0.1s;">
        <button
          class="feature-video-trigger"
          type="button"
          data-feature-video-trigger
          data-feature-title="Node Hierarchy Drilldown"
          data-feature-full-webm={withBase('/images/feature_node_hierarchy_preview.webm')}
          data-feature-full-mp4={withBase('/images/feature_node_hierarchy_preview.mp4')}
          data-feature-poster={withBase('/images/feature_node_hierarchy_poster.webp')}
          aria-label="Open full demo for Node Hierarchy Drilldown"
        >
          <video
            class="feature-video-preview"
            data-feature-video
            muted
            loop
            playsinline
            preload="none"
            poster={withBase('/images/feature_node_hierarchy_poster.webp')}
          >
            <source src={withBase('/images/feature_node_hierarchy_preview.webm')} type="video/webm" />
            <source src={withBase('/images/feature_node_hierarchy_preview.mp4')} type="video/mp4" />
          </video>
          <span class="feature-video-overlay">Open demo</span>
        </button>
        <h3>Node Hierarchy Drilldown</h3>
        <p>
          Move from high-level graph to detailed node information and relations.
        </p>
      </div>
      <div class="card reveal feature-card" style="animation-delay: 0.15s;">
        <button
          class="feature-video-trigger"
          type="button"
          data-feature-video-trigger
          data-feature-title="Runtime Metrics"
          data-feature-full-webm={withBase('/images/feature_runtime_metrics_preview.webm')}
          data-feature-full-mp4={withBase('/images/feature_runtime_metrics_preview.mp4')}
          data-feature-poster={withBase('/images/feature_runtime_metrics_poster.webp')}
          aria-label="Open full demo for Runtime Metrics"
        >
          <video
            class="feature-video-preview"
            data-feature-video
            muted
            loop
            playsinline
            preload="none"
            poster={withBase('/images/feature_runtime_metrics_poster.webp')}
          >
            <source src={withBase('/images/feature_runtime_metrics_preview.webm')} type="video/webm" />
            <source src={withBase('/images/feature_runtime_metrics_preview.mp4')} type="video/mp4" />
          </video>
          <span class="feature-video-overlay">Open demo</span>
        </button>
        <h3>Runtime Metrics</h3>
        <p>
          Track counters and timing signals to spot load, churn, and bottlenecks.
        </p>
      </div>
      <div class="card reveal feature-card" style="animation-delay: 0.2s;">
        <button
          class="feature-video-trigger"
          type="button"
          data-feature-video-trigger
          data-feature-title="Replay and Chains"
          data-feature-full-webm={withBase('/images/feature_replay_chains_preview.webm')}
          data-feature-full-mp4={withBase('/images/feature_replay_chains_preview.mp4')}
          data-feature-poster={withBase('/images/feature_replay_chains_poster.webp')}
          aria-label="Open full demo for Replay and Chains"
        >
          <video
            class="feature-video-preview"
            data-feature-video
            muted
            loop
            playsinline
            preload="none"
            poster={withBase('/images/feature_replay_chains_poster.webp')}
          >
            <source src={withBase('/images/feature_replay_chains_preview.webm')} type="video/webm" />
            <source src={withBase('/images/feature_replay_chains_preview.mp4')} type="video/mp4" />
          </video>
          <span class="feature-video-overlay">Open demo</span>
        </button>
        <h3>Replay and Chains</h3>
        <p>
          Rewind recorded sessions and inspect event chains step by step.
        </p>
      </div>
      <div class="card reveal feature-card" style="animation-delay: 0.25s;">
        <button
          class="feature-video-trigger"
          type="button"
          data-feature-video-trigger
          data-feature-title="IDE Integration"
          data-feature-full-webm={withBase('/images/feature_ide_integration_preview.webm')}
          data-feature-full-mp4={withBase('/images/feature_ide_integration_preview.mp4')}
          data-feature-poster={withBase('/images/feature_ide_integration_poster.webp')}
          aria-label="Open full demo for IDE Integration"
        >
          <video
            class="feature-video-preview"
            data-feature-video
            muted
            loop
            playsinline
            preload="none"
            poster={withBase('/images/feature_ide_integration_poster.webp')}
          >
            <source src={withBase('/images/feature_ide_integration_preview.webm')} type="video/webm" />
            <source src={withBase('/images/feature_ide_integration_preview.mp4')} type="video/mp4" />
          </video>
          <span class="feature-video-overlay">Open demo</span>
        </button>
        <h3>IDE Integration</h3>
        <p>
          Jump from map to code and launch Uyava Desktop directly from your IDE.
        </p>
      </div>
    </div>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="Roadmap"
      title="Planned and experimental ideas"
      description="These are research tracks, not shipped functionality."
    />
    <Callout title="Planned or experimental (not guaranteed)">
      <ul>
        <li>
          <strong>Planned:</strong> Local API mode — drive Uyava Desktop from any app/module via
          localhost commands.
        </li>
        <li>
          <strong>Experimental:</strong> LLM-assisted insights for architecture review from logs,
          metrics, and runtime activity.
        </li>
      </ul>
      <p>
        We will clearly mark these features before any public release.
      </p>
    </Callout>
  </section>

  <section class="container">
    <SectionHeader
      eyebrow="Get started"
      title="Move from flat logs to living architecture"
      description="Start with free DevTools or the free desktop app, then add Pro when you need advanced replay."
    />
    <div class="hero-actions">
      <a class="btn primary" href={withBase('/download')}>Go to downloads</a>
      <a class="btn" href={withBase('/docs')}>Open documentation</a>
    </div>
  </section>

  <div class="hero-video-modal" data-hero-video-modal aria-hidden="true">
    <button
      type="button"
      class="hero-video-modal-backdrop"
      data-hero-video-close
      aria-label="Close full demo"
    ></button>
    <div class="hero-video-modal-dialog" role="dialog" aria-modal="true" aria-label="Uyava desktop demo">
      <button type="button" class="hero-video-close" data-hero-video-close>Close</button>
      <video
        class="hero-video-full"
        data-hero-video-full
        controls
        playsinline
        preload="none"
        poster={withBase('/images/hero_courier_burst_poster.webp')}
      >
        <source src={withBase('/images/hero_courier_burst_full.webm')} type="video/webm" />
        <source src={withBase('/images/hero_courier_burst_full.mp4')} type="video/mp4" />
      </video>
    </div>
  </div>

  <div class="hero-video-modal feature-video-modal" data-feature-video-modal aria-hidden="true">
    <button
      type="button"
      class="hero-video-modal-backdrop"
      data-feature-video-close
      aria-label="Close feature demo"
    ></button>
    <div
      class="hero-video-modal-dialog feature-video-modal-dialog"
      role="dialog"
      aria-modal="true"
      aria-label="Feature demo"
    >
      <button type="button" class="hero-video-close" data-feature-video-close>Close</button>
      <p class="feature-video-modal-title" data-feature-video-title></p>
      <video class="hero-video-full" data-feature-video-full controls playsinline preload="none">
        <source data-feature-video-source-webm type="video/webm" />
        <source data-feature-video-source-mp4 type="video/mp4" />
      </video>
    </div>
  </div>

  <script is:inline>
    (() => {
      const preview = document.querySelector('[data-hero-video-preview]');
      const openButton = document.querySelector('[data-hero-video-open]');
      const modal = document.querySelector('[data-hero-video-modal]');
      const fullVideo = document.querySelector('[data-hero-video-full]');
      const closeButtons = document.querySelectorAll('[data-hero-video-close]');
      const featureTriggers = Array.from(
        document.querySelectorAll('[data-feature-video-trigger]'),
      );
      const featureVideos = Array.from(document.querySelectorAll('[data-feature-video]'));
      const featureModal = document.querySelector('[data-feature-video-modal]');
      const featureFullVideo = document.querySelector('[data-feature-video-full]');
      const featureVideoTitle = document.querySelector('[data-feature-video-title]');
      const featureVideoSourceWebm = document.querySelector('[data-feature-video-source-webm]');
      const featureVideoSourceMp4 = document.querySelector('[data-feature-video-source-mp4]');
      const featureCloseButtons = document.querySelectorAll('[data-feature-video-close]');
      const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

      const stopVideo = (video) => {
        if (!video) return;
        video.pause();
        video.currentTime = 0;
      };

      const stopAllFeatureVideos = (except) => {
        featureVideos.forEach((video) => {
          if (video !== except) stopVideo(video);
        });
      };

      const stopHeroModal = () => {
        if (!modal || !fullVideo) return;
        fullVideo.pause();
        fullVideo.currentTime = 0;
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('video-modal-open');
      };

      const stopFeatureModal = () => {
        if (!featureModal || !featureFullVideo) return;
        featureFullVideo.pause();
        featureFullVideo.currentTime = 0;
        featureModal.classList.remove('is-open');
        featureModal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('video-modal-open');
      };

      if (modal && fullVideo && openButton) {
        const openModal = () => {
          stopFeatureModal();
          modal.classList.add('is-open');
          modal.setAttribute('aria-hidden', 'false');
          document.body.classList.add('video-modal-open');
          fullVideo.currentTime = 0;
          const playPromise = fullVideo.play();
          if (playPromise && typeof playPromise.catch === 'function') {
            playPromise.catch(() => {});
          }
        };

        if (supportsHover && preview) {
          const stopPreview = () => {
            preview.pause();
            preview.currentTime = 0;
          };
          openButton.addEventListener('mouseenter', () => {
            const playPromise = preview.play();
            if (playPromise && typeof playPromise.catch === 'function') {
              playPromise.catch(() => {});
            }
          });
          openButton.addEventListener('mouseleave', stopPreview);
          openButton.addEventListener('blur', stopPreview);
        }

        openButton.addEventListener('click', openModal);
        closeButtons.forEach((button) => button.addEventListener('click', stopHeroModal));
      }

      const openFeatureModal = (trigger) => {
        if (!featureModal || !featureFullVideo) return;
        const webm = trigger.dataset.featureFullWebm;
        const mp4 = trigger.dataset.featureFullMp4;
        const poster = trigger.dataset.featurePoster;
        const title = trigger.dataset.featureTitle;

        stopHeroModal();
        stopAllFeatureVideos();

        if (featureVideoSourceWebm) {
          if (webm) {
            featureVideoSourceWebm.setAttribute('src', webm);
          } else {
            featureVideoSourceWebm.removeAttribute('src');
          }
        }
        if (featureVideoSourceMp4) {
          if (mp4) {
            featureVideoSourceMp4.setAttribute('src', mp4);
          } else {
            featureVideoSourceMp4.removeAttribute('src');
          }
        }
        if (poster) {
          featureFullVideo.setAttribute('poster', poster);
        } else {
          featureFullVideo.removeAttribute('poster');
        }
        if (featureVideoTitle) {
          featureVideoTitle.textContent = title || 'Feature demo';
        }

        featureFullVideo.load();
        featureModal.classList.add('is-open');
        featureModal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('video-modal-open');
        const playPromise = featureFullVideo.play();
        if (playPromise && typeof playPromise.catch === 'function') {
          playPromise.catch(() => {});
        }
      };

      featureCloseButtons.forEach((button) => button.addEventListener('click', stopFeatureModal));

      window.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        if (featureModal && featureModal.classList.contains('is-open')) {
          stopFeatureModal();
          return;
        }
        if (modal && modal.classList.contains('is-open')) {
          stopHeroModal();
        }
      });

      featureTriggers.forEach((trigger) => {
        const video = trigger.querySelector('[data-feature-video]');
        if (!video) return;

        if (supportsHover) {
          trigger.addEventListener('mouseenter', () => {
            stopAllFeatureVideos(video);
            const playPromise = video.play();
            if (playPromise && typeof playPromise.catch === 'function') {
              playPromise.catch(() => {});
            }
          });
          trigger.addEventListener('mouseleave', () => stopVideo(video));
          trigger.addEventListener('blur', () => stopVideo(video));
          trigger.addEventListener('click', () => openFeatureModal(trigger));
          return;
        }

        trigger.addEventListener('click', () => {
          openFeatureModal(trigger);
        });
      });
    })();
  </script>
</BaseLayout>
